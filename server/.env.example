PORT=4000
HOST=0.0.0.0
# Relative to the server package root unless absolute
DATABASE_PATH=data/cartscout.sqlite

# Auth (min 32 chars for JWT_ACCESS_SECRET in production)
JWT_ACCESS_SECRET=change-me-to-a-long-random-string-at-least-32
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_DAYS=7
BCRYPT_ROUNDS=12
