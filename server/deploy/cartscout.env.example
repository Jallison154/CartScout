# CartScout API — copy to /opt/cartscout/cartscout.env and edit (chmod 600).
# Loaded by PM2 via server/deploy/ecosystem.config.cjs
#
# iPhone on same Wi‑Fi: set EXPO_PUBLIC_API_URL in the app to:
#   http://<this-server-LAN-IP>:4000
# Ensure HOST=0.0.0.0 so the API listens on all interfaces (not only localhost).

NODE_ENV=production
PORT=4000
HOST=0.0.0.0

# SQLite file (absolute path recommended on servers)
DATABASE_PATH=/opt/cartscout/data/cartscout.sqlite

# Required in production (min 32 characters). Generate e.g.:
#   openssl rand -base64 48
JWT_ACCESS_SECRET=change-me-to-a-long-random-string-at-least-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_DAYS=7
BCRYPT_ROUNDS=12
