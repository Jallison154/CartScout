# Backend API (no trailing slash). Required for `npm run dev` (Vite on :5173, API elsewhere).
# Leave unset when you build for production and serve the UI from Express (`WEB_UI_DIST` on the server):
# the app will use the same origin as the page (e.g. http://vm-ip:4000).
VITE_API_URL=http://127.0.0.1:4000
