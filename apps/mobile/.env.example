# Backend API origin (no trailing slash). Embedded at build time — set per build profile.
#
# Local / simulator (same machine):
#   EXPO_PUBLIC_API_URL=http://127.0.0.1:4000
# Physical iPhone on Wi‑Fi (use your Mac or server LAN IP):
#   EXPO_PUBLIC_API_URL=http://192.168.1.10:4000
#
# TestFlight / App Store builds: set EXPO_PUBLIC_API_URL for the EAS "production" environment
# (Expo dashboard → Project → Environment variables), or see:
# https://docs.expo.dev/eas/environment-variables/
# Do not commit secrets; HTTPS strongly recommended for production.
EXPO_PUBLIC_API_URL=http://127.0.0.1:4000
